PORT=4000
CORS_ORIGIN=http://localhost:3000
PAYSTACK_CALLBACK_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/gigshub_clone?schema=public
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=
JWT_AUDIENCE=
MIN_PASSWORD_LENGTH=8
MAX_ORDER_LINE_QUANTITY=5

AUTH_LOGIN_WINDOW_MS=300000
AUTH_LOGIN_LIMIT=10
AUTH_REGISTER_WINDOW_MS=600000
AUTH_REGISTER_LIMIT=5
AUTH_PASSWORD_RESET_WINDOW_MS=600000
AUTH_PASSWORD_RESET_LIMIT=5
AUTH_REFRESH_WINDOW_MS=60000
AUTH_REFRESH_LIMIT=30

PAYMENT_INITIALIZE_WINDOW_MS=60000
PAYMENT_INITIALIZE_LIMIT=20
PAYMENT_COMPLETE_WINDOW_MS=60000
PAYMENT_COMPLETE_LIMIT=60

WEBHOOK_WINDOW_MS=60000
WEBHOOK_LIMIT=120
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345!

# GrandAPI (daytime provider)
GRANDAPI_API_KEY=your_grandapi_api_key
GRANDAPI_BASE_URL=https://grandapi.duckdns.org/api
GRANDAPI_NETWORK_MAP={"mtn":"MTN","telecel":"TELECEL","airteltigo":"AIRTELTIGO","at-bigtime":"AIRTELTIGO"}
GRANDAPI_CAPACITY_MAP={}
GRANDAPI_PACKAGE_MAP={}
GRANDAPI_BUNDLE_TYPE=EXPIRING
GRANDAPI_CALLBACK_URL=https://your-api-host/api/grandapi/webhook?token=<secret>
GRANDAPI_WEBHOOK_TOKEN=your_grandapi_webhook_token
GRANDAPI_PACKAGE_CACHE_TTL_MS=300000

#GRANDAPI_CALLBACK_URL=https://lofaq-data-hub.onrender.com/api/grandapi/webhook?token=<secret> and set the same value in GRANDAPI_WEBHOOK_TOKEN
# Encart (forceable provider)
ENCART_API_KEY=your_encart_api_key
ENCART_BASE_URL=https://encartastores.com/api
ENCART_NETWORK_MAP={"mtn":"YELLO","telecel":"TELECEL","airteltigo":"AT_PREMIUM","at-bigtime":"AT_BIGTIME"}
ENCART_CAPACITY_MAP={}

# Datahubnet (night provider)
DATAHUBNET_API_KEY=your_datahubnet_api_key
DATAHUBNET_BASE_URL=https://www.datahubnet.online/api
DATAHUBNET_AUTH_SCHEME=Api-Key
DATAHUBNET_AUTH_SCHEME_STATUS=
DATAHUBNET_TELECEL_NETWORK=telecel
DATAHUBNET_CAPACITY_MAP={}

# Fulfillment dispatcher
FULFILLMENT_DISPATCH_INTERVAL_MS=13000
